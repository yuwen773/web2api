TAIJI_API_BASE=https://ai.aurod.cn
TAIJI_ACCOUNT=your_account
TAIJI_PASSWORD=your_password
TAIJI_APP_VERSION=2.14.0

WEB2API_HOST=0.0.0.0
WEB2API_PORT=8000
# Backward-compatible aliases for host/port are still supported:
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

MAX_CONCURRENT=5

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=both
LOG_DIRECTORY=./logs
LOG_MAX_SIZE_MB=100
LOG_BACKUP_COUNT=30
LOG_COMPRESS_DAYS=7

# 监控配置
MONITORING_ENABLED=true
METRICS_ENDPOINT=/metrics
STATS_ENDPOINT=/stats
STATS_REFRESH_SEC=5
